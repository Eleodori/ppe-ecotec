{
  "//": [
    "Type-check di JS via JSDoc. Solo per gli editor (VSCode/Cursor) e per la CI:",
    "non è una compilazione, l'app continua a girare senza build (ADR-001)."
  ],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "src/core/**/*.js",
    "tests/**/*.js"
  ]
}
